# --- Serveur ---
PORT=3000
# URL publique du service (sans slash final), pour générer le bookmarklet.
BASE_URL=https://newsletter-tech.up.railway.app
# Secret partagé bookmarklet <-> serveur. Génère-le avec :
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
CAPTURE_TOKEN=change-moi

# --- Stockage ---
# En local, laisse ./data. Sur Railway, monte un VOLUME sur ce chemin.
DATA_DIR=/data

# --- Email (Resend) ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Expéditeur sur ton domaine vérifié dans Resend.
MAIL_FROM=articles@ton-domaine.com
MAIL_TO=guillaumelockhart@vivaldi.net
# Plafond DUR de la boîte de réception, en Mo.
EMAIL_LIMIT_MB=7

# --- Compression des images (à la capture) ---
IMAGE_MAX_WIDTH=1000
IMAGE_QUALITY=72

# --- Cron d'envoi quotidien (in-process) ---
CRON_ENABLED=true
CRON_SCHEDULE=0 6 * * *
CRON_TZ=Europe/Paris
